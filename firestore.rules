rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is main admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/admin/credentials) &&
             get(/databases/$(database)/documents/admin/credentials).data.email == request.auth.token.email;
    }
    
    // Check if user is admin or moderator (main admin OR in admin_users collection)
    function isAdminOrModerator() {
      return isAdmin() || 
             (request.auth != null && 
              exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)));
    }
    
    // Check if user is super admin (main admin OR role='admin' in admin_users)
    function isSuperAdmin() {
      return isAdmin() || 
             (request.auth != null && 
              exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Check if user is verified seller
    function isVerifiedSeller() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.verificationStatus == 'VERIFIED';
    }
    
    // Check if user owns the resource
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // ============================================
    // ADMIN COLLECTION - Admin credentials
    // ============================================
    match /admin/credentials {
      allow read: if request.auth != null;
      allow create: if request.auth != null && !exists(/databases/$(database)/documents/admin/credentials);
      allow update: if false; // Admin cannot be updated, only reset
      allow delete: if request.auth != null; // For reset functionality
    }
    
    // ============================================
    // ADMIN USERS - Super Admin can manage
    // ============================================
    match /admin_users/{adminId} {
      allow read: if isAdminOrModerator(); // All admins/moderators can read
      allow create: if isSuperAdmin(); // Only super admin can add new admins/moderators
      allow update: if isSuperAdmin(); // Only super admin can update
      allow delete: if isSuperAdmin(); // Only super admin can delete
    }
    
    // ============================================
    // SYSTEM SETTINGS - Anyone can read, only super admin can write
    // ============================================
    match /system_settings/{settingId} {
      allow read: if true; // Anyone can read (app needs to fetch commission settings)
      allow write: if isSuperAdmin(); // Only super admin can modify settings
    }
    
    // ============================================
    // REPORTS AND COMPLAINTS - Users can create, admins can manage
    // ============================================
    match /reports/{reportId} {
      allow read: if request.auth != null || isAdminOrModerator();
      allow create: if request.auth != null;
      allow update: if isAdminOrModerator() || 
                      (request.auth != null && request.auth.uid == resource.data.reporterId);
      allow delete: if isAdminOrModerator();
    }
    
    // ============================================
    // ORDERS - Admin can do everything
    // ============================================
    match /orders/{orderId} {
      allow read: if request.auth != null || isAdmin();
      allow create: if request.auth != null;
      allow update: if request.auth != null || isAdmin();
      allow delete: if isAdmin() || 
                      (request.auth != null && 
                       (resource.data.buyerId == request.auth.uid || 
                        resource.data.sellerId == request.auth.uid));
    }
    
    // ============================================
    // STRIPE REFUND TRACKING - System & Admin only
    // ============================================
    match /stripe_refund_tracking/{paymentIntentId} {
      allow read: if request.auth != null || isAdmin();
      allow write: if request.auth != null || isAdmin(); // App needs to write
    }
    
    // ============================================
    // PRODUCTS - Admin can approve/reject/delete
    // ============================================
    match /data/stock/products/{productId} {
      allow read: if true; // Public read for browsing
      
      // Sellers can create products
      allow create: if request.auth != null && 
                      request.auth.uid == request.resource.data.sellerId &&
                      isVerifiedSeller() &&
                      request.resource.data.status == 'pending' &&
                      request.resource.data.rejectionReason == null &&
                      request.resource.data.reviewedBy == null;
      
      // Admin can approve/reject products
      allow update: if isAdmin() ||
                      (request.auth != null && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'rejectionReason', 'reviewedBy', 'reviewedAt']) &&
                       request.resource.data.status in ['approved', 'rejected']) ||
                      (request.auth != null && 
                       request.auth.uid == resource.data.sellerId &&
                       isVerifiedSeller() &&
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'rejectionReason', 'reviewedBy', 'reviewedAt', 'sellerId']) &&
                       request.resource.data.sellerId == resource.data.sellerId);
      
      // Admin can delete any product
      allow delete: if isAdmin() || 
                      (request.auth != null && request.auth.uid == resource.data.sellerId);
    }
    
    // ============================================
    // USERS - Admin can read/update all users
    // ============================================
    match /users/{userId} {
      allow read: if true; // Open read for dashboard
      
      // Users can update their own profile (except verification fields)
      allow update: if isAdmin() ||
                      (request.auth != null && request.auth.uid == userId &&
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['verificationStatus', 'verifiedAt', 'isVerifiedSeller', 'verificationRejectionReason', 'role']));
      
      // Admin can update verification status
      allow update: if isAdmin() ||
                      (request.auth != null &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['verificationStatus', 'verifiedAt', 'isVerifiedSeller', 'verificationRejectionReason', 'reviewedBy']));
      
      allow create: if request.auth != null;
      
      // Admin can delete users
      allow delete: if isAdmin();
    }
    
    // ============================================
    // WALLET TRANSACTIONS - Admin can read all
    // ============================================
    match /wallet_transactions/{transactionId} {
      allow read: if isAdmin() || 
                    (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // ============================================
    // CATEGORIES - Admin can manage
    // ============================================
    match /data/categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() || request.auth != null;
    }
    
    // ============================================
    // LEARNING RESOURCES - Categories
    // ============================================
    match /learning_resources_categories/{categoryId} {
      allow read: if true; // Public read for sellers
      allow write: if isAdmin(); // Only admin can manage via dashboard
    }
    
    // ============================================
    // LEARNING RESOURCES - Tutorials
    // ============================================
    match /learning_resources_tutorials/{tutorialId} {
      allow read: if true; // Public read for sellers
      allow write: if isAdmin(); // Only admin can manage via dashboard
    }
    
    // ============================================
    // CO-SELLER STORES - Admin can manage all
    // ============================================
    match /coSellerStores/{storeId} {
      allow read: if true; // Public read
      
      // Verified sellers can create stores
      allow create: if request.auth != null && isVerifiedSeller() &&
                      request.auth.uid == request.resource.data.ownerSellerId;
      
      // Admin can update any store, sellers can update their own
      allow update: if isAdmin() ||
                      (request.auth != null && isVerifiedSeller() &&
                       ((request.auth.uid == resource.data.ownerSellerId) ||
                        (resource.data.keys().hasAny(['coSellerIds']) && 
                         request.auth.uid in resource.data.coSellerIds) ||
                        (resource.data.keys().hasAny(['coSellerId']) && 
                         request.auth.uid == resource.data.coSellerId) ||
                        (request.resource.data.keys().hasAny(['coSellerIds']) &&
                         request.auth.uid in request.resource.data.coSellerIds &&
                         !(resource.data.keys().hasAny(['coSellerIds']) && 
                           request.auth.uid in resource.data.coSellerIds))));
      
      // Admin can delete any store, owners can delete their own
      allow delete: if isAdmin() ||
                      (request.auth != null && 
                       request.auth.uid == resource.data.ownerSellerId &&
                       isVerifiedSeller());
    }
    
    // ============================================
    // STORE INVITES - Admin can read all
    // ============================================
    match /storeInvites/{inviteId} {
      allow read: if request.auth != null || isAdmin();
      allow create: if request.auth != null && isVerifiedSeller() &&
                      request.auth.uid == request.resource.data.ownerSellerId;
      allow update: if isAdmin() ||
                      (request.auth != null &&
                       (request.auth.uid == resource.data.invitedSellerId ||
                        request.auth.uid == resource.data.ownerSellerId));
      allow delete: if isAdmin() ||
                      (request.auth != null &&
                       request.auth.uid == resource.data.ownerSellerId);
    }
    
    // ============================================
    // CHATS - Admin can read all
    // ============================================
    match /chats/{chatId} {
      allow read: if request.auth != null || isAdmin();
      allow create: if request.auth != null;
      allow update: if request.auth != null || isAdmin();
      allow delete: if isAdmin();
    }
    
    // ============================================
    // CHAT MESSAGES - Admin can read all
    // ============================================
    match /chats/{chatId}/messages/{messageId} {
      allow read: if request.auth != null || isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // ============================================
    // VERIFICATION REQUESTS - Admin can manage
    // ============================================
    match /verificationRequests/{requestId} {
      allow read: if true; // Open read for dashboard
      allow create: if request.auth != null;
      allow update: if isAdmin() || request.auth != null;
      allow delete: if isAdmin();
    }
    
    // ============================================
    // NEGOTIATION REQUESTS - Admin can read all
    // ============================================
    match /negotiationRequests/{requestId} {
      allow read: if request.auth != null || isAdmin();
      allow create: if request.auth != null;
      allow update: if request.auth != null || isAdmin();
      allow delete: if request.auth != null || isAdmin();
    }
    
    match /negotiation_requests/{requestId} {
      allow read: if request.auth != null || isAdmin();
      allow create: if request.auth != null;
      allow update: if request.auth != null || isAdmin();
      allow delete: if request.auth != null || isAdmin();
    }
    
    // ============================================
    // FAVOURITES
    // ============================================
    match /users/{userId}/favourites/{productId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ============================================
    // COMMISSIONS - Admin only
    // ============================================
    match /commissions/{commissionId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // ============================================
    // ANALYTICS - Admin only
    // ============================================
    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // ============================================
    // FALLBACK - Read only for authenticated users
    // ============================================
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
  